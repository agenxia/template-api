{
  "name": "API Agent",
  "description": "Advanced agent with external API integrations, webhooks, and caching",
  "type": "template",
  "complexity": "intermediate",
  "features": [
    "External API integrations",
    "Webhook support",
    "Built-in caching",
    "Rate limiting",
    "Error handling",
    "Request validation"
  ],
  "env_vars": [
    "AGENT_NAME",
    "AGENT_ID",
    "PLATFORM_URL",
    "PORT",
    "CACHE_TTL",
    "RATE_LIMIT",
    "LLM_API_KEY",
    "LLM_API_URL"
  ],
  "icon": "🔌",
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}. {{AGENT_DESCRIPTION}}",
    "model": "llama-3.3-70b",
    "temperature": 0.7,
    "max_tokens": 4096
  }
}