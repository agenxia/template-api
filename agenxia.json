{
  "name": "{{AGENT_NAME}}",
  "version": "1.0.0",
  "description": "{{AGENT_DESCRIPTION}}",
  "type": "agent",
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}, a data processing API agent.",
    "model": "llama-3.3-70b",
    "temperature": 0.3,
    "max_tokens": 4096
  },
  "env_vars": ["LLM_API_URL", "LLM_API_KEY"],
  "ports": {
    "inputs": [
      { "id": "data", "label": "Data", "type": "text" },
      { "id": "operation", "label": "Operation", "type": "text" }
    ],
    "outputs": [
      { "id": "result", "label": "Result", "type": "text" },
      { "id": "error", "label": "Error", "type": "text" }
    ]
  },
  "methods": [
    {
      "name": "process",
      "description": "Process data with a given operation",
      "params": {
        "data": { "type": "string", "from_port": "data" },
        "operation": { "type": "string", "from_port": "operation" }
      },
      "returns": {
        "result": { "type": "string", "to_port": "result" },
        "error": { "type": "string", "to_port": "error" }
      }
    }
  ],
  "api": {
    "process": { "type": "post", "description": "Process data" },
    "status": { "type": "get", "description": "Agent status" }
  }
}