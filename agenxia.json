{
  "name": "API Agent",
  "description": "Advanced agent with external API integrations, webhooks, and caching",
  "type": "template",
  "complexity": "intermediate",
  "features": [
    "External API integrations",
    "Webhook support",
    "Built-in caching",
    "Rate limiting",
    "Error handling",
    "Request validation"
  ],
  "env_vars": [
    "AGENT_NAME",
    "AGENT_ID",
    "PLATFORM_URL",
    "PORT",
    "CACHE_TTL",
    "RATE_LIMIT",
    "LLM_API_KEY",
    "LLM_API_URL"
  ],
  "icon": "🔌",
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}. {{AGENT_DESCRIPTION}}",
    "model": "llama-3.3-70b",
    "temperature": 0.7,
    "max_tokens": 4096
  },
  "methods": [
    {
      "name": "chat",
      "description": "Send a message and get a response",
      "params": {
        "messages": {
          "type": "array",
          "required": true,
          "description": "Array of {role, content} messages"
        },
        "context": {
          "type": "object",
          "required": false,
          "description": "Optional context"
        }
      },
      "returns": {
        "content": {
          "type": "string",
          "description": "Agent response"
        },
        "metadata": {
          "type": "object",
          "description": "{ model, tokens }"
        }
      },
      "example": {
        "request": {
          "jsonrpc": "2.0",
          "id": 1,
          "method": "chat",
          "params": {
            "messages": [
              {
                "role": "user",
                "content": "Hello"
              }
            ]
          }
        },
        "response": {
          "jsonrpc": "2.0",
          "id": 1,
          "result": {
            "content": "Hi! How can I help?",
            "metadata": {
              "model": "llama-3.3-70b"
            }
          }
        }
      }
    }
  ],
  "api": [
    {
      "method": "GET",
      "path": "/health",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/.well-known/agent-card.json",
      "description": "Agent discovery card"
    },
    {
      "method": "GET",
      "path": "/docs",
      "description": "API documentation (HTML)"
    },
    {
      "method": "POST",
      "path": "/api/a2a",
      "description": "A2A JSON-RPC 2.0 endpoint"
    }
  ],
  "metadata": {
    "author": "agenxia",
    "source_template": null,
    "type": "template"
  }
}